# OpenAI settings
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_VERIFY_MODEL=gpt-4o-mini
OPENAI_STRICT_JSON_ONLY=1

# Usage quota (server-side enforcement)
QUOTA_ENABLED=1
QUOTA_CHAT_DAILY_LIMIT=20
QUOTA_CHAT_MONTHLY_LIMIT=0
QUOTA_ANALYZE_DAILY_LIMIT=0
QUOTA_ANALYZE_MONTHLY_LIMIT=30

# Chat routing / guardrail
CHAT_ROUTER_MODEL=gpt-4o-mini
CHAT_ROUTER_CONFIDENCE_THRESHOLD=0.65
CHAT_MIN_RELEVANCE_SCORE=0.0
CHAT_OFFTOPIC_STRICT=1
CHAT_ROUTER_LOG_PATH=./reports/router_telemetry.jsonl

# Kira opinion assistant
KIRA_OPINION_ENABLED=1
KIRA_OPINION_MODEL=gpt-4o-mini
KIRA_OPINION_TEMPERATURE=0.2
KIRA_OPINION_BALANCED_VARIANT=a
KIRA_OPINION_AB_ENABLED=1
OPINION_EXPERIMENT_LOG_PATH=./reports/opinion_experiment.jsonl

# Auth mode / social login
AUTH_MODE=social_only
SOCIAL_LOGIN_GOOGLE_URL=https://your-domain.com/auth/google/login
SOCIAL_LOGIN_KAKAO_URL=https://your-domain.com/auth/kakao/login
SOCIAL_AUTH_CALLBACK_URL=https://your-domain.com/auth/callback
SOCIAL_AUTH_LOGOUT_URL=/auth/logout

# Supabase JWT verify (Auth Gateway)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_ISSUER=https://your-project.supabase.co/auth/v1
SUPABASE_AUDIENCE=authenticated
SUPABASE_ALLOWED_ALGORITHMS=RS256
SOCIAL_AUTH_ALLOWED_REDIRECTS=/tool,/

# Auth cookie (issued by Auth Gateway)
AUTH_COOKIE_NAME=kira_auth
AUTH_COOKIE_SECURE=1
AUTH_COOKIE_PATH=/
AUTH_COOKIE_DOMAIN=
AUTH_SESSION_TTL_DAYS=7

# UI / deployment flags
PDF_VIEWER_REQUIRED=1
COMPANY_DOC_DELETE_COOLDOWN_SECONDS=60
ENABLE_DOC_GATE=0
SHOW_DOC_TYPE_UI=0

# Admin dashboard
SUPER_ADMIN_USERNAMES=admin
OPERATOR_USERNAMES=operator
ADMIN_USERNAMES=
ADMIN_ALERT_AUTO_PERSIST=1
ADMIN_ALERT_LOG_PATH=./reports/admin_alerts.jsonl
ADMIN_ALERT_MIN_EVENTS=20
ADMIN_ALERT_BLOCK_SPIKE_FACTOR=1.8
ADMIN_ALERT_BLOCK_ABS_DELTA=0.10
ADMIN_ALERT_FAILURE_DELTA=0.08
ADMIN_ALERT_FAILURE_THRESHOLD=0.35
ADMIN_ALERT_COOLDOWN_MINUTES=60

# Web runtime API
WEB_API_HOST=0.0.0.0
WEB_API_PORT=8010
WEB_API_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,null
WEB_SESSION_TTL_HOURS=12

# Google OAuth (FastAPI /auth/google/*)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_OAUTH_POST_LOGIN_URL=http://localhost:3000/
GOOGLE_OAUTH_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_OAUTH_USERINFO_URL=https://openidconnect.googleapis.com/v1/userinfo
GOOGLE_OAUTH_SCOPES=openid email profile

# Local 개발에서는 http 환경이므로 0 권장
AUTH_COOKIE_SECURE=0
